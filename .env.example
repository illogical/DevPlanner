# =============================================================================
# DevPlanner Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# The .env file is gitignored — never commit secrets or local paths.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------------

# Absolute path to the workspace directory where all project data is stored.
# This directory holds per-project subdirectories with Markdown cards and JSON
# metadata. Create the directory before starting the server.
#
# Example (local):  DEVPLANNER_WORKSPACE=/home/alice/devplanner-workspace
# Example (Docker): DEVPLANNER_WORKSPACE=/workspace  (set automatically)
DEVPLANNER_WORKSPACE=/path/to/your/workspace

# -----------------------------------------------------------------------------
# OPTIONAL — Server
# -----------------------------------------------------------------------------

# Port the backend API server listens on.
# The frontend Vite dev server proxies /api requests to this port.
# Default: 17103
# PORT=17103

# -----------------------------------------------------------------------------
# OPTIONAL — Backups
# -----------------------------------------------------------------------------

# Directory where workspace backups are stored.
# Default: {DEVPLANNER_WORKSPACE}/_backups
# DEVPLANNER_BACKUP_DIR=/path/to/backups

# -----------------------------------------------------------------------------
# OPTIONAL — File Watcher
# -----------------------------------------------------------------------------

# Set to "true" to disable the filesystem watcher that detects external changes
# (e.g. edits made directly in the workspace by another tool or AI agent).
# Useful when debugging WebSocket behavior in isolation.
# Default: false
# DISABLE_FILE_WATCHER=false

# -----------------------------------------------------------------------------
# OPTIONAL — Artifact Vault Integration
# -----------------------------------------------------------------------------

# Base URL prefix for vault file links. DevPlanner appends the encoded relative
# path to construct the full link URL. Set this to the base viewer URL including
# any subfolder already included in ARTIFACT_BASE_PATH.
#
# Example: if your vault root is ~/notes/MyVault and ARTIFACT_BASE_PATH is
# ~/notes/MyVault/10-Projects, then:
#   ARTIFACT_BASE_PATH=~/notes/MyVault/10-Projects
#   ARTIFACT_BASE_URL=https://your-vault-app.example.com/view?path=10-Projects
#
# Resulting URL: {ARTIFACT_BASE_URL}%2F{project}%2F{card}%2F{timestamp}_{LABEL-SLUG}.md
# ARTIFACT_BASE_URL=

# Absolute path to the directory where artifact files are written.
# DEVPLANNER_WORKSPACE is the kanban workspace and remains separate from this path.
# Artifact files are written to: {ARTIFACT_BASE_PATH}/{project-slug}/{card-slug}/
# ARTIFACT_BASE_PATH=/path/to/artifact/vault/subfolder
