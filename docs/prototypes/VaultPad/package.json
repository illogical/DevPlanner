{
  "name": "vaultpad",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run build:client && bun --watch src/server.ts",
    "start": "bun run build:client && bun src/server.ts",
    "test": "bun test",
    "e2e": "bun scripts/e2e.ts",
    "smoke": "bun scripts/smoke-url.ts",
    "validate:inline": "bun scripts/validate-inline-script.ts",
    "build:client": "bun build src/client.tsx --outdir public --target=browser --format=esm",
    "build": "bun run build:client",
    "check:types": "tsc --noEmit",
    "verify": "bun run check:types && bun test && bun run e2e && bun run validate:inline \"http://localhost:17104/editor?path=20-Knowledge/operations/2026-02-28_00-26-00-agentvault-markdown-qmd-handoff-summary.md\"",
    "resolve-link": "bun scripts/resolve-link.ts"
  },
  "dependencies": {
    "lucide-preact": "^0.575.0",
    "marked": "^16.2.1",
    "preact": "^10.28.4"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "bun-types": "^1.3.10",
    "typescript": "^5.9.3"
  }
}
